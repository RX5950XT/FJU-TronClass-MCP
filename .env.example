# 輔大 TronClass session cookie（從 Chrome DevTools 複製）
# TRONCLASS_SESSION_COOKIE=V2-xxxxxxxxxxxxxxxx

# 覆寫預設 Base URL（通常不需更動）
# TRONCLASS_BASE_URL=https://elearn2.fju.edu.tw

# 預設下載目錄（預設：~/Downloads/TronClass）
# FJUMCP_DOWNLOAD_DIR=D:/Downloads/TronClass

# Log level: DEBUG / INFO / WARNING / ERROR（預設：INFO）
# FJUMCP_LOG_LEVEL=INFO
